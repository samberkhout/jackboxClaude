# ── Supabase ────────────────────────────────────────────────────────────────
# Verplicht voor database + storage
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Optioneel: service role key geeft schrijfrechten op storage zonder RLS-check
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Groq ─────────────────────────────────────────────────────────────────────
# Vereist voor de Digital Sous-Chef chatbot (/sous-chef)
# Gratis account + API key aanmaken op: https://console.groq.com
# Gratis tier: 14.400 requests/dag, geen creditcard nodig
GROQ_API_KEY=gsk_...

# ── Web Push / VAPID ─────────────────────────────────────────────────────────
# Vereist voor prijswijzigings-notificaties (price-intelligence)
# Genereer een keypair met: npx web-push generate-vapid-keys
VAPID_MAILTO=mailto:sam@hopenbites.nl
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BA...
VAPID_PRIVATE_KEY=...
