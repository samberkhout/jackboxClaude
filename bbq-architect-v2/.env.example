# ── Supabase (via Vercel Integration) ────────────────────────────────────────
# Automatisch ingevuld door de Vercel × Supabase integratie
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJ...

SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_PUBLISHABLE_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_SECRET_KEY=...
SUPABASE_JWT_SECRET=...

# ── Postgres (via Vercel Integration) ────────────────────────────────────────
POSTGRES_DATABASE=postgres
POSTGRES_HOST=db.<project>.supabase.co
POSTGRES_USER=postgres
POSTGRES_PASSWORD=...
POSTGRES_PRISMA_URL=postgresql://postgres:...@db.<project>.supabase.co:5432/postgres?pgbouncer=true
POSTGRES_URL_NON_POOLING=postgresql://postgres:...@db.<project>.supabase.co:5432/postgres

# ── Groq ─────────────────────────────────────────────────────────────────────
# Verplicht voor de Digital Sous-Chef chatbot
# Gratis account aanmaken op https://console.groq.com → API Keys
GROQ_API_KEY=gsk_...

# ── Web Push / VAPID ─────────────────────────────────────────────────────────
# Optioneel — alleen nodig voor push-notificaties bij prijswijzigingen
# Genereer eenmalig met: npx web-push generate-vapid-keys
# VAPID_MAILTO=mailto:sam@hopenbites.nl
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=BA...
# VAPID_PRIVATE_KEY=...
